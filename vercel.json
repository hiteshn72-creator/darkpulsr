{
  "version": 2,
  "name": "darkpulsr",
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/(.*\\.(css|html|js|ico|png|svg|woff2?))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
